---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Sign In — AI Pods">
  <main class="flex min-h-screen items-center justify-center px-4 bg-[#080a0f]">
    <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-12 text-center max-w-md">
      <div class="mb-5 flex items-center justify-center gap-2">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-600 text-white text-sm font-bold">AI</span>
        <span class="text-lg font-semibold text-white">AI Pods</span>
      </div>
      <h1 class="mb-3 text-2xl font-bold text-white">Sign In</h1>
      <p class="text-sm text-zinc-400 mb-6">
        Authentication will be available once Clerk is configured. Check back soon.
      </p>
      <a href="/" class="inline-flex h-10 items-center justify-center rounded-lg border border-white/10 px-6 text-sm font-medium text-zinc-300 transition hover:border-white/20 hover:text-white">
        ← Back to home
      </a>
    </div>
  </main>
</Layout>
