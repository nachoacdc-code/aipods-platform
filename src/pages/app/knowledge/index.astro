---
import AppLayout from '../../../layouts/AppLayout.astro';
import KnowledgeCenter from '../../../components/knowledge/KnowledgeCenter';
---

<AppLayout title="Knowledge Center — AIpods">
  <div class="px-8 py-10">
    <div class="mb-10">
      <h1 class="text-2xl font-bold text-white">Knowledge Center</h1>
      <p class="mt-1 text-sm text-zinc-500">
        Upload documents, notes, and data that your pods use to learn your business.
        Everything is encrypted in your browser before it reaches our servers.
      </p>
    </div>

    <KnowledgeCenter client:load />
  </div>
</AppLayout>
