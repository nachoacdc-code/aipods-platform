---
import AppLayout from '../../../layouts/AppLayout.astro';
---

<AppLayout title="Usage — AIpods">
  <div class="px-8 py-10">
    <div class="mb-10">
      <h1 class="text-2xl font-bold text-white">Usage</h1>
      <p class="mt-1 text-sm text-zinc-500">Track your AI Task Unit consumption and activity.</p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-4">
      {[
        { label: 'Units Used', value: '0', sub: 'this month' },
        { label: 'Units Remaining', value: '∞', sub: 'MVP — unlimited testing' },
        { label: 'Tasks Run', value: '0', sub: 'this month' },
        { label: 'Avg. Time/Task', value: '—', sub: 'no tasks yet' },
      ].map(stat => (
        <div class="rounded-xl border border-white/5 bg-white/[0.02] p-5">
          <p class="text-2xl font-bold text-white">{stat.value}</p>
          <p class="mt-1 text-xs font-medium text-zinc-400">{stat.label}</p>
          <p class="text-xs text-zinc-600">{stat.sub}</p>
        </div>
      ))}
    </div>

    <div class="mt-10 rounded-2xl border border-white/5 bg-white/[0.02] p-8">
      <h2 class="mb-2 text-lg font-semibold text-white">Activity Log</h2>
      <p class="text-sm text-zinc-500">Task history will appear here once you start running pods.</p>
      <div class="mt-6 flex items-center justify-center rounded-xl border border-dashed border-white/10 py-16 text-sm text-zinc-600">
        No activity yet
      </div>
    </div>
  </div>
</AppLayout>
