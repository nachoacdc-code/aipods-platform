---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AIpods — Your AI Department, Ready Now">
  <header class="fixed top-0 z-50 w-full border-b border-white/5 bg-[#080a0f]/80 backdrop-blur-md">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2.5">
        <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-blue-500 text-white text-xs font-bold">AI</span>
        <span class="text-sm font-semibold tracking-wide text-white">AIpods</span>
      </a>
      <div class="hidden items-center gap-8 md:flex">
        <a href="#how-it-works" class="text-sm text-zinc-400 transition hover:text-white">How It Works</a>
        <a href="#pricing" class="text-sm text-zinc-400 transition hover:text-white">Pricing</a>
        <a href="/trust" class="text-sm text-zinc-400 transition hover:text-white">Trust</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="/sign-in" class="text-sm text-zinc-400 transition hover:text-white">Sign in</a>
        <a href="/sign-up" class="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-blue-500">
          Start Free
        </a>
      </div>
    </nav>
  </header>

  <main>
    <section class="relative flex min-h-screen items-center justify-center overflow-hidden bg-[#080a0f] px-6 pt-24 pb-32">
      <div class="pointer-events-none absolute inset-0"
        style="background-image: linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px); background-size: 64px 64px;">
      </div>
      <div class="pointer-events-none absolute left-1/2 top-1/2 h-[900px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full"
        style="background: radial-gradient(ellipse at center, rgba(59,130,246,0.12) 0%, transparent 65%);">
      </div>

      <div class="relative z-10 mx-auto max-w-5xl text-center">
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/5 px-4 py-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
          <span class="text-xs font-medium tracking-widest text-blue-400 uppercase">Now in Early Access</span>
        </div>

        <h1 class="mb-6 font-bold tracking-tight text-white" style="font-size: clamp(2.5rem, 7vw, 5.5rem); line-height: 1.08; letter-spacing: -0.03em;">
          AIpods —<br />
          <span style="background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 50%, #f472b6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            Your Autonomous Teams
          </span>
        </h1>

        <p class="mx-auto mb-12 max-w-2xl text-lg leading-relaxed text-zinc-400">
          An entire AI department — sales, marketing, creative, research, ops — that works 24/7,
          gets smarter every month, and costs a fraction of a human team.
          Scale faster than you ever thought possible.
        </p>

        <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href="/sign-up"
            class="group relative inline-flex h-12 items-center justify-center overflow-hidden rounded-lg px-8 text-sm font-semibold text-white transition-all"
            style="background: linear-gradient(135deg, #2563eb, #7c3aed);">
            <span class="relative z-10">Start Free — 40 Units/mo</span>
            <div class="absolute inset-0 opacity-0 transition group-hover:opacity-100"
              style="background: linear-gradient(135deg, #3b82f6, #8b5cf6);"></div>
          </a>
          <a href="#how-it-works"
            class="inline-flex h-12 items-center justify-center rounded-lg border border-white/10 bg-white/5 px-8 text-sm font-medium text-zinc-300 backdrop-blur transition hover:border-white/20 hover:bg-white/10 hover:text-white">
            See How It Works
          </a>
        </div>

        <p class="mt-8 text-xs text-zinc-600">
          Works 24/7 · Gets smarter every month · 1/10th the cost of a human team
        </p>

        <div class="mx-auto mt-20 grid max-w-4xl grid-cols-2 gap-4 sm:grid-cols-4">
          {[
            { label: 'Marketing Pod', desc: 'Content, SEO, campaigns',  icon: '📣', color: 'from-blue-500/10 to-blue-600/5', border: 'border-blue-500/20' },
            { label: 'Sales Pod',     desc: 'Leads, outreach, signals', icon: '💼', color: 'from-violet-500/10 to-violet-600/5', border: 'border-violet-500/20' },
            { label: 'Ops Pod',       desc: 'Workflows, automation',    icon: '⚙️',  color: 'from-emerald-500/10 to-emerald-600/5', border: 'border-emerald-500/20' },
            { label: 'Creative Pod',  desc: 'Design, video, assets',    icon: '🎨', color: 'from-amber-500/10 to-amber-600/5', border: 'border-amber-500/20' },
          ].map(pod => (
            <div class={`rounded-xl border ${pod.border} bg-gradient-to-b ${pod.color} p-4 text-center backdrop-blur`}>
              <div class="mb-2 text-2xl">{pod.icon}</div>
              <p class="text-xs font-medium text-zinc-300">{pod.label}</p>
              <p class="mt-1 text-[10px] text-zinc-600">{pod.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="how-it-works" class="bg-[#080a0f] px-6 py-32">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-blue-500">How It Works</p>
          <h2 class="text-4xl font-bold tracking-tight text-white">Deploy your AI team in minutes.</h2>
          <p class="mt-4 text-zinc-400">Your pods learn your business, deliver results, and get better every single week.</p>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {[
            {
              step: '01',
              title: 'Teach It Your Business',
              desc: 'Share your strategy docs, ICP profiles, sales scripts, and anything your team needs to know. Your Knowledge Center grows over time.',
              icon: '🧠',
            },
            {
              step: '02',
              title: 'Deploy a Pod',
              desc: 'Pick a pod — Marketing, Sales, Ops, Creative, Research. Your AI team gets to work instantly, armed with everything they know about your business.',
              icon: '🚀',
            },
            {
              step: '03',
              title: 'Watch It Compound',
              desc: 'Every task makes your AI team smarter. New pods instantly know everything previous ones learned. Your competitive advantage grows daily.',
              icon: '📈',
            },
          ].map(f => (
            <div class="group rounded-2xl border border-white/5 bg-white/[0.02] p-8 transition hover:border-blue-500/30 hover:bg-blue-500/5">
              <div class="mb-5 flex items-center gap-3">
                <span class="text-2xl">{f.icon}</span>
                <span class="text-xs font-mono text-blue-500">{f.step}</span>
              </div>
              <h3 class="mb-3 text-lg font-semibold text-white">{f.title}</h3>
              <p class="text-sm leading-relaxed text-zinc-400">{f.desc}</p>
            </div>
          ))}
        </div>

        <div class="mt-16 grid grid-cols-2 gap-6 border-t border-white/5 pt-16 sm:grid-cols-4">
          {[
            { value: '1/10th', label: 'the cost of a human team' },
            { value: '24/7',   label: 'always working for you' },
            { value: '∞',      label: 'knowledge that compounds' },
            { value: '<8 min', label: 'to deploy your first pod' },
          ].map(s => (
            <div class="text-center">
              <p class="text-3xl font-bold text-white">{s.value}</p>
              <p class="mt-1 text-xs text-zinc-500">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="pricing" class="bg-[#060810] px-6 py-32">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 text-center">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-blue-500">Pricing</p>
          <h2 class="text-4xl font-bold tracking-tight text-white">Simple, predictable pricing.</h2>
          <p class="mt-4 text-zinc-400">No token roulette. One flat monthly fee, unlimited team members.</p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { name: 'Starter',    price: '$69',    units: '180',    per: '$0.38/unit', highlight: false, badge: '' },
            { name: 'Growth',     price: '$199',   units: '650',    per: '$0.31/unit', highlight: false, badge: '' },
            { name: 'Scale',      price: '$499',   units: '2,200',  per: '$0.23/unit', highlight: true,  badge: 'Most Popular' },
            { name: 'Enterprise', price: '$1,499+', units: '8,000+', per: 'Negotiated', highlight: false, badge: '' },
          ].map(tier => (
            <div class={`relative flex flex-col rounded-2xl border p-7 transition ${
              tier.highlight
                ? 'border-blue-500/40 bg-gradient-to-b from-blue-500/10 to-transparent'
                : 'border-white/5 bg-white/[0.02] hover:border-white/10'
            }`}>
              {tier.badge && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-blue-600 px-3 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-white">
                  {tier.badge}
                </span>
              )}
              <p class="mb-1 text-sm font-medium text-zinc-400">{tier.name}</p>
              <p class="mb-1 text-4xl font-bold text-white">{tier.price}</p>
              <p class="mb-6 text-xs text-zinc-500">per month · annual –20%</p>
              <div class="mb-6 space-y-2 border-t border-white/5 pt-6 text-sm text-zinc-300">
                <p><span class="font-semibold text-white">{tier.units}</span> AI Task Units</p>
                <p class="text-xs text-zinc-500">{tier.per}</p>
                <p class="text-xs text-zinc-500">30% unit rollover</p>
                <p class="text-xs text-zinc-500">$0.99 overage/unit</p>
              </div>
              <a href="/sign-up"
                class={`mt-auto block rounded-lg py-2.5 text-center text-sm font-medium transition ${
                  tier.highlight
                    ? 'bg-blue-600 text-white hover:bg-blue-500'
                    : 'border border-white/10 text-zinc-300 hover:border-white/20 hover:text-white'
                }`}>
                Get Started
              </a>
            </div>
          ))}
        </div>

        <p class="mt-8 text-center text-sm text-zinc-600">
          +25% bonus units on any upgrade (first month) · Annual billing saves 20%
        </p>
      </div>
    </section>

    <section class="bg-[#080a0f] px-6 py-24">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="mb-4 text-4xl font-bold tracking-tight text-white">
          Your AI department starts today.
        </h2>
        <p class="mb-10 text-zinc-400">
          Free plan includes 40 AI Task Units per month. No credit card required.
        </p>
        <a href="/sign-up"
          class="inline-flex h-12 items-center justify-center rounded-lg px-10 text-sm font-semibold text-white transition-all hover:scale-105"
          style="background: linear-gradient(135deg, #2563eb, #7c3aed);">
          Start Free Now
        </a>
      </div>
    </section>

    <footer class="border-t border-white/5 bg-[#080a0f] px-6 py-10">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
        <div class="flex items-center gap-2.5">
          <span class="flex h-6 w-6 items-center justify-center rounded-md bg-blue-500 text-white text-[10px] font-bold">AI</span>
          <span class="text-sm font-semibold text-white">AIpods</span>
        </div>
        <p class="text-xs text-zinc-600">
          © 2026 AIpods
        </p>
        <div class="flex gap-5">
          <a href="/sign-in" class="text-xs text-zinc-600 hover:text-zinc-400 transition">Sign in</a>
          <a href="/sign-up" class="text-xs text-zinc-600 hover:text-zinc-400 transition">Sign up</a>
          <a href="#pricing" class="text-xs text-zinc-600 hover:text-zinc-400 transition">Pricing</a>
          <a href="/trust" class="text-xs text-zinc-600 hover:text-zinc-400 transition">Trust & Security</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>
