---
import '../styles/globals.css';
import { isClerkConfigured } from '../lib/auth';

interface Props {
  title?: string;
}

const { title = 'AI Pods — Dashboard' } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#080a0f] font-sans antialiased text-zinc-100">
    <div class="flex h-screen overflow-hidden">
      <aside class="hidden w-60 shrink-0 flex-col border-r border-white/5 bg-[#060810] md:flex">
        <div class="flex items-center gap-2.5 border-b border-white/5 px-5 py-4">
          <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-blue-600 text-white text-xs font-bold">AI</span>
          <span class="text-sm font-semibold text-white">AI Pods</span>
        </div>
        <nav class="flex-1 space-y-1 px-3 py-4">
          {[
            { label: 'My Pods',           href: '/app',             icon: '⬡' },
            { label: 'Knowledge Center',  href: '/app/knowledge',   icon: '🧠' },
            { label: 'Usage',             href: '/app/usage',       icon: '📊' },
            { label: 'Billing',           href: '/app/billing',     icon: '💳' },
            { label: 'Growth Reports',    href: '/app/reports',     icon: '📈' },
          ].map(item => (
            <a
              href={item.href}
              class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-zinc-400 transition hover:bg-white/5 hover:text-white"
            >
              <span class="text-base">{item.icon}</span>
              {item.label}
            </a>
          ))}
        </nav>
        <div class="border-t border-white/5 px-4 py-4">
          <a href="/" class="block rounded-lg px-3 py-2 text-xs text-zinc-600 transition hover:text-zinc-400">
            ← Back to home
          </a>
        </div>
      </aside>

      <main class="flex-1 overflow-y-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
