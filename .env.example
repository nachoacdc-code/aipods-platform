# =============================================================
# AIpods Platform — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================

# ── MVP Auth (founder-only) ──────────────────────────────────
# Set a strong password. This is the only credential needed for MVP.
ADMIN_PASSWORD=replace_with_a_strong_password

# ── LLM API Keys ────────────────────────────────────────────
ANTHROPIC_API_KEY=replace_with_your_anthropic_key
XAI_API_KEY=replace_with_your_xai_key
GOOGLE_AI_API_KEY=replace_with_your_google_ai_key

# ── Supabase ────────────────────────────────────────────────
# Obtain from: https://supabase.com/dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_service_role_key

# ── Vercel Cron ────────────────────────────────────────────
# Secret to authenticate cron job requests. Set in Vercel dashboard.
CRON_SECRET=replace_with_a_random_secret

# ── App ─────────────────────────────────────────────────────
PUBLIC_APP_URL=http://localhost:4321

# ── Clerk (deferred — not used in MVP) ──────────────────────
# PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
